# VoiceForge Configuration
# All vars prefixed with VF_

# Core
VF_SECRET_KEY=change-me-to-something-secure
VF_DEBUG=false

# TTS Engine (default: xtts)
VF_DEFAULT_TTS_ENGINE=xtts
VF_XTTS_DEVICE=cpu

# OpenAI TTS (optional)
# VF_OPENAI_API_KEY=sk-...
# VF_OPENAI_TTS_MODEL=tts-1-hd
# VF_OPENAI_DEFAULT_VOICE=nova

# ElevenLabs (optional)
# VF_ELEVENLABS_API_KEY=...

# Ollama (optional)
# VF_OLLAMA_BASE_URL=http://localhost:11434
# VF_OLLAMA_TTS_MODEL=outetts

# CORS
VF_CORS_ORIGINS=["http://localhost:3000"]
